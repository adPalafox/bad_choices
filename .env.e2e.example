# Copy this file to .env.e2e and replace the key placeholders with the values from:
#   supabase start
#   supabase db reset
#   supabase status -o env

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-status
BAD_CHOICES_TEST_RANDOM_SEED=bad-choices-e2e
BAD_CHOICES_TEST_FORCE_DETOURS=friends_5:special,friends_9:wildcard,date_5:special,date_9:wildcard,team_5:special,team_9:wildcard

